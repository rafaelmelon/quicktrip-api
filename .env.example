# Database
DATABASE_URL="postgresql://quicktrip:quicktrip@localhost:5432/quicktrip?schema=public"

# JWT
JWT_SECRET="change-me-to-a-random-64-char-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3000
HOST="0.0.0.0"
NODE_ENV="development"

# CORS — comma-separated origins allowed
CORS_ORIGINS="http://localhost:8081,http://localhost:19006"

# Google Maps (server-side key for Places API, optional)
GOOGLE_MAPS_API_KEY=""
